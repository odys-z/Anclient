import { SMenu, SCard, SHeader, SIcon, SButton, STip, STag } from "@surrealism/index.slint";
import { UseIcons } from "@surrealism/use/index.slint";

import { TableViewPage } from "./table_view_page.slint";
import { CustomTableViewPage } from "./custom-table.slint";
import { HomeForm } from "home.slint";
import { GUIClientSettings } from "gui-settings.slint";
import { PathItemData, FileTable } from "file-table.slint";

export component App inherits Window {
    preferred-height: 800px;
    preferred-width: 1280px;

    min-height: 600px;
    min-width: 800px;

    in-out property <string> window-title: "Anclient.slint";
    title: window-title;

    private property <string> menu_id;

    out property <length> web_x;
    out property <length> web_y;
    out property <length> web_width;
    out property <length> web_height;

    in-out property <string> webview-status: "Webview not started";
    in-out property <string> syncing-status: "Ready";

    in-out property <string> current_pth;
    in-out property <[PathItemData]> filelist: [];

    callback menu-changed(int, string, string);
    callback item_clicked(string, bool);
    callback echows(string);
    callback pingws([string]);
    callback load_folder(string);
    callback select_file(PathItemData, bool);
    callback upload_files();

    HorizontalLayout {
      left-wrapper:=Rectangle {
        z: 111;
        height: 100%;
        width: menu.width;
        clip: false;
        menu:=SMenu {
          menu-data:[
            { id: "home",  icon:UseIcons.icons.FileCode, name: "Home" },
            { id: "album", icon:UseIcons.icons.Share,    name: "Album"},
            { id: "files", icon:UseIcons.icons.Folder,   name: "Files"},
            { id: "help",  icon:UseIcons.icons.Help,     name: "Help" },
          ];

          change(index, data) => {
            debug(index, data);
            menu_id = data.id;
            menu-changed(index, data.id, data.name);
          }
        }
      }

      right-wrapper:=Rectangle {
        z: 100;
        width: parent.width - menu.width;
        background: #2b2b32;
        VerticalLayout {
          width: parent.width;
          height: parent.height;

          if (menu_id == "home") : index-page := HomeForm { 
            height: parent.height - 14pt;
            visible: root.menu_id == "home";
            pingws-clicked => { root.pingws(["file-1", "file-2"]); }
          }

          if (menu_id == "album") : webview_slot := Rectangle {
            background: #e0e0e0;
            Text { text: "Page 2"; }
          }

          if (menu_id == "files") : Rectangle {
            background: #b0d0d0;
            CustomTableViewPage { width: 100%; height: 100%; }
          }

          if (menu_id == "help") : Rectangle {
            background: #202020;
            FileTable { width: 100%; height: 100%;
              row_data: root.filelist;
              init => { root.load_folder("."); }
              current_path: root.current_pth;
              row-double-click(row) => {
                if (row.is-folder) {
                  debug("[App Window] callback, loading: " + row.fname);
                  root.load_folder(row.fullpath);
                }
              }
              row-selected(row) => {
                if (!row.is-folder) {
                  debug("[App Window] callback, synching: " + row.fname);
                  root.select_file(row, row.iselected);
                }
              }
              upload => {
                root.upload_files();
              }
            }
          }

          if (menu_id == "2-2") : Rectangle {
            background: #b0d0d0;
            GUIClientSettings {
              width: 100%; height: 100%;
              echows-clicked(msg) => { root.echows(msg); }
              pingws-clicked => { root.pingws(self.file_paths)}
            }
          }

          status-bar:= HorizontalLayout {
            padding-top: 1pt;
            padding-left: 12pt;
            STag{ text: root.syncing_status; }
          }
        }
      }
    }

    popup:=STip {
      text: "Credits to: SurrealismUI";
      position: Bottom;
    }
}
